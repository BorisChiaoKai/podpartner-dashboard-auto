# PodPartner Dashboard Auto-Update Pipeline
# Environment Variables Configuration

# ============================================
# REDDIT API
# ============================================
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=PodPartnerDashboard/1.0

# ============================================
# GOOGLE TRENDS
# ============================================
# No authentication needed for pytrends (unofficial API)
# All queries are automatic

# ============================================
# META (FACEBOOK) ADS API
# ============================================
# Get from: https://business.facebook.com/
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_meta_ad_account_id_here

# ============================================
# YOUTUBE API
# ============================================
# Get from: https://console.cloud.google.com/
# Enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# TRUSTPILOT
# ============================================
# Your business URL on Trustpilot
TRUSTPILOT_BUSINESS_URL=https://www.trustpilot.com/review/podpartner.com

# ============================================
# NETLIFY DEPLOYMENT
# ============================================
# Get from: https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here
NETLIFY_SITE_ID=your_netlify_site_id_here

# ============================================
# OPTIONAL: SLACK NOTIFICATIONS
# ============================================
# Uncomment to enable Slack notifications on deployment
# SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ============================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ============================================
# Uncomment to enable email notifications on failure
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here
# NOTIFICATION_EMAIL=recipient@example.com
